# Vendored sources are huge git clones — re-created by scripts/setup.sh
# from Skal's forks at the commits pinned in
# patches/{bun,webkit}-skal-commit.txt.
vendor/

# Build artifacts. All outputs of scripts/build-*.sh and scripts/link-skal-so.sh.
build/
zig-out/
.zig-cache/

# Editor / OS / agent noise
.DS_Store
.idea/
.vscode/
.claude/

# Node deps (only in vendor/bun anyway, but defensive)
node_modules/

# Build leftovers (defensive — most live under build/ already)
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.aar
*.apk
*.aab

# Rust target dirs (defensive — bun's lolhtml lands in build/)
target/

# Local Android SDK/NDK config someone might drop here
android/local.properties
android/.gradle/
android/build/
android/jniLibs/

# Workspace-managed node_modules for each example. Bun hoists shared
# deps to the root node_modules/, but workspace-linked deps land here
# too (kitchen-sink/node_modules/skal → packages/skal-js, etc.).
examples/*/node_modules
packages/*/node_modules

# Vite build outputs for the web target — emitted by `bun run build:web`.
examples/*/dist

# Dart pub tool caches + plugin metadata for workspace packages.
# Regenerated by `flutter pub get` from each package's pubspec.yaml.
packages/*/.dart_tool/
packages/*/.flutter-plugins-dependencies
# Library packages don't pin a lockfile — only apps under examples/ do.
packages/*/pubspec.lock

# Website live-gallery embeds — build outputs (bun run build:web / build:web-flutter
# in examples/gallery, then copy dist/ + flutter-host/build/web here; see
# website/build-components.mjs + examples/gallery/scripts/shoot-gallery.sh)
website/gallery/
website/gallery-flutter/
examples/gallery/flutter-host/web/skal-app.js

# Gallery JS bundle + JSC bytecode — build outputs of `bun run build`
# (the .cjs.jsc is JSC-version-keyed and regenerated on every JS change).
# The gallery is not CI-built and its bundle is rebuilt by the docs
# pipeline, so it's not tracked. (kitchen-sink, which IS CI-built, keeps
# its committed bundle.)
examples/gallery/flutter-host/assets/skal-app.js
examples/gallery/flutter-host/assets/skal-app.cjs
examples/gallery/flutter-host/assets/skal-app.cjs.jsc
