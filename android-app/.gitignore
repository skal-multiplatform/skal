# Gradle
.gradle/
build/
local.properties

# Generated APKs / native libs (built by scripts/build-app.sh)
**/jniLibs/*/libskal.so
**/jniLibs/*/libc++_shared.so
*.apk
*.aab

# JS bundle build outputs — regenerated by scripts/build-app.sh /
# js-app/package.json's build:* scripts. Kept untracked because:
#   1. .cjs.jsc bytecode is non-deterministic across bun runs (we
#      observed 228K vs 234K for the same input on consecutive runs);
#      tracking it churns diffs on every developer machine.
#   2. .js bundle is regenerated from js-app/src/ via Vite; the
#      checked-in source of truth is the JSX, not the bundle.
#   3. .cjs is regenerated from skal-app.js via vendor/bun's bundler.
# A clean checkout still produces a working APK because
# scripts/build-app.sh runs the bundle steps before APK assembly.
**/assets/skal-app.js
**/assets/skal-app.cjs
**/assets/skal-app.cjs.jsc

# Editor
.idea/
*.iml

# Mac
.DS_Store
