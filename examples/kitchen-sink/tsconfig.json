{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "types": ["bun"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Mirror the Vite resolve.alias entries so the IDE's TS service
    // can follow `import { ListView } from 'skal'` to the actual
    // module file. Without this, cmd-click + hover + auto-complete
    // all silently fail for these bare specifiers — TS doesn't read
    // Vite's config.
    "baseUrl": ".",
    "paths": {
      "skal": ["./src/skal/index.js"],
      "~renderer": ["./src/renderer.js"]
    },

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
