{
  "name": "skal-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && bun run build:bytecode",
    "build:js-only": "vite build",
    "build:bytecode": "bun build ../android-app/app/src/main/assets/skal-app.js --bytecode --format=cjs --outdir=../android-app/app/src/main/assets/ --entry-naming=skal-app.cjs --root=../android-app/app/src/main/assets && mv ../android-app/app/src/main/assets/skal-app.cjs.jsc ../android-app/app/src/main/assets/skal-app.cjs.jsc",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "esbuild": "^0.28.0",
    "vite": "^8.0.11",
    "vite-plugin-solid": "^2.11.12"
  }
}
