{
  "name": "skal-monorepo",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Skal \u2014 Solid \u2192 bridge \u2192 Flutter app framework. Internal monorepo: framework in packages/, apps in examples/.",
  "workspaces": [
    "packages/*",
    "examples/*",
    "site"
  ],
  "scripts": {
    "_three_commands": "// \u2500\u2500\u2500 the three commands you usually run \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500",
    "setup": "./scripts/setup.sh",
    "new": "./scripts/new-app.sh",
    "_dev_demo": "// \u2500\u2500\u2500 kitchen-sink demo (= bun --filter kitchen-sink <task>) \u2500\u2500",
    "dev:macos": "bun --filter kitchen-sink dev:macos",
    "dev:ios": "bun --filter kitchen-sink dev:ios",
    "dev:android": "bun --filter kitchen-sink dev:android",
    "dev:web": "bun --filter kitchen-sink dev:web",
    "build": "bun --filter kitchen-sink build",
    "_repo_wide": "// \u2500\u2500\u2500 repo-wide tasks \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500",
    "test": "bun run test:codegen && bun run test:flutter",
    "test:codegen": "cd packages/skal_codegen && dart test --exclude-tags integration",
    "test:flutter": "cd packages/skal_flutter && flutter test",
    "analyze": "cd packages/skal_flutter && dart analyze lib/ test/ && cd ../skal_codegen && dart analyze lib/ bin/",
    "link": "./scripts/skal-link.sh",
    "_low_level": "// \u2500\u2500\u2500 lower-level (setup.sh wraps these; call them directly only for incremental re-builds) \u2500\u2500",
    "build:libskal": "cd vendor/bun && PATH=\"$HOME/.cargo/bin:$PATH\" bun run build:release",
    "build:libskal:android": "ANDROID_NDK_ROOT=${ANDROID_NDK_ROOT:-/opt/homebrew/share/android-ndk} bun --cwd vendor/bun scripts/build.ts --profile=android-release --build-dir=$(pwd)/vendor/bun/build/android"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6"
  }
}