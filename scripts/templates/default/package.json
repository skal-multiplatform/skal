{
  "name": "__APP_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Skal app.",
  "scripts": {
    "build": "vite build && bun run build:bytecode",
    "build:js-only": "vite build",
    "build:bytecode": "bash -c 'BUN=$(./scripts/find-vendored-bun.sh) && \"$BUN\" build ./flutter-host/assets/skal-app.js --bytecode --format=cjs --outdir=./flutter-host/assets/ --entry-naming=skal-app.cjs --root=./flutter-host/assets'",
    "dev": "vite build --watch",
    "dev:web": "vite --config vite.config.web.js",
    "build:web": "vite build --config vite.config.web.js"
  },
  "dependencies": {
    "skal": "workspace:*",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "esbuild": "^0.28.0",
    "vite": "^8.0.11",
    "vite-plugin-solid": "^2.11.12"
  }
}
