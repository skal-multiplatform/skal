# Kotlin/Native cinterop spec for the Skal C entry surface.
#
# Phase 4 (the cinterop scaffold) originally shipped an inline C stub
# embedded directly in this .def — useful for proving the pipeline
# linked end-to-end without a real bun-iOS runtime. As of Phase 2's
# iOS-Simulator shortcut (the LC_BUILD_VERSION re-stamp from MACOS to
# IOSSIMULATOR via vtool, see scripts/link-skal-iossim.sh), the inline
# stub is gone and we link against the real libskal.dylib instead.
#
# Real iOS device targets still need a from-source bun-iOS build, NOT
# the re-stamped dylib (which only works on Simulator because the
# Simulator runs arm64 darwin code natively over the macOS kernel).
# When that lib exists, point libraryPaths at it via the same DSL.

package = com.skal.bridge.cinterop
language = C

# headers — basename only; absolute include path is provided by Gradle
# via includeDirs(...). Same skal.h that documents the C ABI for both
# the iOS-Simulator path and the eventual iOS-device build.
headers = skal.h
headerFilter = skal.h

# noStringConversion — keep `const char*` as `CPointer<ByteVar>` instead
# of nullable `String?` for skal_evaluate. The strings here are byte
# spans with explicit length parameters, NOT null-terminated.
noStringConversion = skal_evaluate

# linkerOpts / library paths are passed through via Gradle's
# `cinterops.compilerOpts` and `extraOpts` — relative paths in this
# file resolve from cinterop's temp dir, not the .def's location, so
# they don't work for repo-anchored directories.
